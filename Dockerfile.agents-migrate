FROM node:22-slim

WORKDIR /inkeep-agents

RUN npm install -g pnpm@10.33.0

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY turbo.json drizzle.manage.config.ts drizzle.run.config.ts ./

RUN pnpm fetch

COPY apps/ ./apps/
COPY scripts/ ./scripts/

RUN pnpm install --frozen-lockfile --offline

# Use drizzle-kit directly for the manage DB migration instead of migrate-dolt.ts.
# migrate-dolt.ts calls doltAddAndCommit (Dolt-specific stored procedures) after running
# the Drizzle migrations — those calls fail with "function dolt_add does not exist" on
# standard Postgres (Neon). drizzle-kit migrate works identically on both Dolt and Postgres.
CMD ["sh", "-c", "pnpm drizzle-kit migrate --config=drizzle.manage.config.ts && node --experimental-strip-types scripts/run-migrate-debug.mjs && pnpm db:auth:init"]
