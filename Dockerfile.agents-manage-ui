FROM node:22-slim

WORKDIR /inkeep-agents

RUN npm install -g pnpm@10.33.0

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN pnpm fetch

COPY scripts/ ./scripts/
COPY apps/shared/ ./apps/shared/
COPY apps/manage-ui/ ./apps/manage-ui/

RUN pnpm install --frozen-lockfile --offline

ENV SKIP_APP_INSTALL="1"

RUN pnpm inkeep dev --export --output-dir ./apps/manage-ui

# Overwrite next.config after export (generated config may lack these flags).
# ignoreBuildErrors prevents type errors in generated code from failing the build.
RUN printf 'import type { NextConfig } from "next";\nconst nextConfig: NextConfig = { typescript: { ignoreBuildErrors: true }, eslint: { ignoreDuringBuilds: true } };\nexport default nextConfig;\n' > ./apps/manage-ui/next.config.ts

WORKDIR /inkeep-agents/apps/manage-ui

RUN pnpm install --no-frozen-lockfile --ignore-scripts

RUN pnpm next build

EXPOSE 3000

CMD ["pnpm", "next", "start"]
