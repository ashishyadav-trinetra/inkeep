FROM node:22-slim

WORKDIR /inkeep-agents

RUN npm install -g pnpm@10.33.0

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN pnpm fetch

COPY scripts/ ./scripts/
COPY apps/shared/ ./apps/shared/
COPY apps/manage-ui/ ./apps/manage-ui/

RUN pnpm install --frozen-lockfile --offline

ENV SKIP_APP_INSTALL="1"

RUN pnpm inkeep dev --export --output-dir ./apps/manage-ui

# Overwrite next.config after export using the version-controlled docker config.
# next.config.docker.ts includes everything the production build needs:
#   - transpilePackages for @inkeep/agents-ui
#   - Turbopack SVG loader (@svgr/webpack) so icons/*.svg imports resolve to React
#     components instead of plain objects (fixes React error #130 "got: object")
#   - serverExternalPackages for OpenTelemetry
#   - rewrites proxying /api, /manage, /run to agents-api (AGENTS_API_URL env var)
# AGENTS_API_URL is read at runtime from the Railway environment variable — no ARG needed.
RUN cp ./apps/manage-ui/next.config.docker.ts ./apps/manage-ui/next.config.ts

WORKDIR /inkeep-agents/apps/manage-ui

RUN pnpm install --no-frozen-lockfile --ignore-scripts

RUN pnpm next build

EXPOSE 3000

CMD ["pnpm", "next", "start"]
