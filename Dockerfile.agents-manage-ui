FROM node:22-slim

WORKDIR /inkeep-agents

RUN npm install -g pnpm@10.33.0

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN pnpm fetch

COPY scripts/ ./scripts/
COPY apps/shared/ ./apps/shared/
COPY apps/manage-ui/ ./apps/manage-ui/

RUN pnpm install --frozen-lockfile --offline

ENV SKIP_APP_INSTALL="1"

RUN pnpm inkeep dev --export --output-dir ./apps/manage-ui

# Overwrite next.config after export.
# - ignoreBuildErrors: prevents type errors in generated code from failing the build.
# - rewrites: proxy /api/* and /manage/* to agents-api so session cookies are
#   served from the same origin as the UI. This lets Next.js middleware read the
#   Better Auth session cookie server-side and avoids cross-domain cookie issues.
ARG AGENTS_API_URL=https://agents-api-inkeep-agents.up.railway.app
RUN printf 'import type { NextConfig } from "next";\nconst nextConfig: NextConfig = { typescript: { ignoreBuildErrors: true }, eslint: { ignoreDuringBuilds: true }, async rewrites() { return [{ source: "/api/:path*", destination: "%s/api/:path*" }, { source: "/manage/:path*", destination: "%s/manage/:path*" }, { source: "/run/:path*", destination: "%s/run/:path*" }]; } };\nexport default nextConfig;\n' "${AGENTS_API_URL}" "${AGENTS_API_URL}" "${AGENTS_API_URL}" > ./apps/manage-ui/next.config.ts

WORKDIR /inkeep-agents/apps/manage-ui

RUN pnpm install --no-frozen-lockfile --ignore-scripts

RUN pnpm next build

EXPOSE 3000

CMD ["pnpm", "next", "start"]
