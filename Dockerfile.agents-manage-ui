FROM node:22-slim

WORKDIR /inkeep-agents

RUN npm install -g pnpm@10.33.0

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN pnpm fetch

COPY scripts/ ./scripts/
COPY apps/shared/ ./apps/shared/
COPY apps/manage-ui/ ./apps/manage-ui/
# Stash the docker config at the workspace root BEFORE export wipes apps/manage-ui/
COPY apps/manage-ui/next.config.docker.ts ./next.config.docker.ts

RUN pnpm install --frozen-lockfile --offline

ENV SKIP_APP_INSTALL="1"

# Export regenerates apps/manage-ui/ (including next.config.ts), so next.config.docker.ts
# must be stashed outside that directory first (done above).
RUN pnpm inkeep dev --export --output-dir ./apps/manage-ui

# Overwrite the exported next.config.ts with our stashed version, which adds:
#   - transpilePackages for @inkeep/agents-ui
#   - Turbopack SVG loader (@svgr/webpack) so icons/*.svg resolve to React components
#     instead of plain objects (fixes React error #130 "Element type is invalid: got object")
#   - serverExternalPackages for OpenTelemetry
#   - rewrites proxying /api, /manage, /run to agents-api (reads AGENTS_API_URL at runtime)
RUN cp ./next.config.docker.ts ./apps/manage-ui/next.config.ts

# Make AGENTS_API_URL available at build time so next.config.ts can bake the
# correct rewrite destination (Railway env vars are only injected at runtime,
# so we must pass this as a build arg before `pnpm next build` runs).
ARG AGENTS_API_URL=https://agents-api-inkeep-agents.up.railway.app
ENV INKEEP_AGENTS_API_URL=${AGENTS_API_URL}

WORKDIR /inkeep-agents/apps/manage-ui

RUN pnpm install --no-frozen-lockfile --ignore-scripts

RUN pnpm next build

EXPOSE 3000

CMD ["pnpm", "next", "start"]
